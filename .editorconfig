root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# JavaScript / TypeScript / JSX / TSX
[*.{ js, jsx, ts, tsx }]
quote_type = single
max_line_length = 120

# JSON files
[*.json]
indent_style = space
indent_size = 2

# YAML files
[*.{ yml, yaml }]
indent_style = space
indent_size = 2
